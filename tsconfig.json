{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "strictPropertyInitialization": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "typeRoots": ["./node_modules/@types", "./src/@types"]  // 👈 KEY FIX
  },
  "include": ["src/**/*"]
}